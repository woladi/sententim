# Dependencies
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build output
dist/
build/
*.tsbuildinfo

# Runtime data
data/raw/
data/staging/
data/cache/
data/.tmp/
*.log

# Local seed artifacts (the LARGE one — produced by `pnpm seed`)
data/seed/

# Env
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Test coverage
coverage/
*.lcov

# Claude Code worktrees
.claude/worktrees/

# SQLite WAL/SHM journal files — always transient
*.db-wal
*.db-shm

# Ship-quality artifacts:
# - data/judgments.db   — bundled inside the npm package, committed to git.
# - data/manifest.json  — same, plain-text mirror of the embedded manifest.
# Listed in package.json "files" → they travel with the published tarball.
